---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const sources = await getCollection('sources');
const recos = await getCollection('recos');
const episodes = await getCollection('episodes');

// Stats par source : nb recos (hors discarded), nb ⭐ confirmées (≥2 LLMs),
// nb épisodes ayant au moins une reco non-discarded.
interface SourceStats {
  recos: number;
  confirmed: number;
  episodes: number;
}
const stats = new Map<string, SourceStats>();
const epWithReco = new Map<string, Set<string>>(); // sourceId → guids d'épisodes
for (const r of recos) {
  if (r.data.status === 'discarded') continue;
  const id = r.data.sourceId.id;
  const s = stats.get(id) ?? { recos: 0, confirmed: 0, episodes: 0 };
  s.recos += 1;
  if ((r.data.extractors?.length ?? 0) >= 2) s.confirmed += 1;
  stats.set(id, s);
  if (!epWithReco.has(id)) epWithReco.set(id, new Set());
  epWithReco.get(id)!.add(r.data.episodeGuid);
}
for (const [id, set] of epWithReco) {
  const s = stats.get(id);
  if (s) s.episodes = set.size;
}

function fmt(n: number): string {
  return n.toLocaleString('fr-FR');
}
---

<Layout title="Reco — les recommandations des podcasts">
  <header class="hero wrap">
    <p class="kicker">Le catalogue des recos</p>
    <h1>Tout ce que vos podcasts<br />vous ont conseillé.</h1>
    <p class="lede">
      Films, séries, livres, musiques… rassemblés, filtrables, avec des liens
      vers des plateformes indépendantes plutôt que les géants.
    </p>
  </header>

  <main class="wrap">
    <ul class="grid sources">
      {
        sources.map((s) => {
          const st = stats.get(s.id) ?? { recos: 0, confirmed: 0, episodes: 0 };
          return (
            <li class="src reveal">
              <a href={`/${s.id}`}>
                <span class="src-count">{fmt(st.recos)} recos</span>
                <h2>{s.data.title}</h2>
                {s.data.tagline && <p class="src-tag">{s.data.tagline}</p>}
                {s.data.hosts.length > 0 && (
                  <p class="src-hosts">par {s.data.hosts.join(' & ')}</p>
                )}
                <p class="src-stats">
                  <span>{fmt(st.episodes)} épisodes</span>
                  {st.confirmed > 0 && (
                    <>
                      <span class="dot">·</span>
                      <span class="conf" title="Recommandations confirmées par 2 LLMs indépendants">
                        ⭐ {fmt(st.confirmed)} confirmées
                      </span>
                    </>
                  )}
                </p>
              </a>
            </li>
          );
        })
      }
    </ul>
  </main>

  <footer class="wrap foot">
    <p>Projet ouvert et duplicable — une source = un podcast.</p>
  </footer>
</Layout>

<style>
  .hero {
    padding: clamp(3rem, 9vw, 7rem) 0 clamp(1.5rem, 4vw, 3rem);
  }
  .kicker {
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.8rem;
    margin: 0 0 0.6rem;
  }
  h1 {
    font-size: clamp(2.6rem, 8vw, 6rem);
  }
  .lede {
    max-width: 46ch;
    color: var(--muted);
    font-size: 1.05rem;
    margin-top: 1.1rem;
  }
  .sources {
    padding-bottom: 4rem;
  }
  .src a {
    display: block;
    height: 100%;
    background: var(--surface);
    border: 1px solid color-mix(in oklab, var(--text) 8%, transparent);
    border-radius: var(--radius);
    padding: 1.4rem;
    text-decoration: none;
    transition:
      transform 0.2s cubic-bezier(0.2, 0.7, 0.2, 1),
      border-color 0.2s ease;
  }
  .src a:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
  }
  .src-count {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
  }
  .src h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin: 0.4rem 0 0.3rem;
  }
  .src-tag {
    margin: 0;
    color: var(--text);
  }
  .src-hosts {
    margin: 0.3rem 0 0;
    color: var(--muted);
    font-size: 0.9rem;
  }
  .src-stats {
    margin: 0.9rem 0 0;
    padding-top: 0.7rem;
    border-top: 1px solid color-mix(in oklab, var(--text) 8%, transparent);
    color: var(--muted);
    font-size: 0.82rem;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem;
  }
  .src-stats .dot {
    opacity: 0.4;
  }
  .src-stats .conf {
    color: var(--accent);
    font-weight: 600;
  }
  .foot {
    padding: 2rem 0 3rem;
    color: var(--muted);
    font-size: 0.85rem;
    border-top: 1px solid color-mix(in oklab, var(--text) 8%, transparent);
  }
</style>
