---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const sources = await getCollection('sources');
const recos = await getCollection('recos');

const countBySource = new Map<string, number>();
for (const r of recos) {
  if (r.data.status === 'discarded') continue; // non comptées publiquement.
  const id = r.data.sourceId.id;
  countBySource.set(id, (countBySource.get(id) ?? 0) + 1);
}
---

<Layout title="Reco — les recommandations des podcasts">
  <header class="hero wrap">
    <p class="kicker">Le catalogue des recos</p>
    <h1>Tout ce que vos podcasts<br />vous ont conseillé.</h1>
    <p class="lede">
      Films, séries, livres, musiques… rassemblés, filtrables, avec des liens
      vers des plateformes indépendantes plutôt que les géants.
    </p>
  </header>

  <main class="wrap">
    <ul class="grid sources">
      {
        sources.map((s) => (
          <li class="src reveal">
            <a href={`/${s.id}`}>
              <span class="src-count">{countBySource.get(s.id) ?? 0} recos</span>
              <h2>{s.data.title}</h2>
              {s.data.tagline && <p class="src-tag">{s.data.tagline}</p>}
              {s.data.hosts.length > 0 && (
                <p class="src-hosts">{s.data.hosts.join(' & ')}</p>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </main>

  <footer class="wrap foot">
    <p>Projet ouvert et duplicable — une source = un podcast.</p>
  </footer>
</Layout>

<style>
  .hero {
    padding: clamp(3rem, 9vw, 7rem) 0 clamp(1.5rem, 4vw, 3rem);
  }
  .kicker {
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.8rem;
    margin: 0 0 0.6rem;
  }
  h1 {
    font-size: clamp(2.6rem, 8vw, 6rem);
  }
  .lede {
    max-width: 46ch;
    color: var(--muted);
    font-size: 1.05rem;
    margin-top: 1.1rem;
  }
  .sources {
    padding-bottom: 4rem;
  }
  .src a {
    display: block;
    height: 100%;
    background: var(--surface);
    border: 1px solid color-mix(in oklab, var(--text) 8%, transparent);
    border-radius: var(--radius);
    padding: 1.4rem;
    text-decoration: none;
    transition:
      transform 0.2s cubic-bezier(0.2, 0.7, 0.2, 1),
      border-color 0.2s ease;
  }
  .src a:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
  }
  .src-count {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
  }
  .src h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin: 0.4rem 0 0.3rem;
  }
  .src-tag {
    margin: 0;
    color: var(--text);
  }
  .src-hosts {
    margin: 0.3rem 0 0;
    color: var(--muted);
    font-size: 0.9rem;
  }
  .foot {
    padding: 2rem 0 3rem;
    color: var(--muted);
    font-size: 0.85rem;
    border-top: 1px solid color-mix(in oklab, var(--text) 8%, transparent);
  }
</style>
