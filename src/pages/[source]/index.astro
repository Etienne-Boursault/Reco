---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import RecoCard from '../../components/RecoCard.astro';
import EmptyState from '../../components/EmptyState.astro';
import { TYPE_LABELS_PLURAL, episodeLabel } from '../../utils/recoTypes';
import { plural } from '../../utils/plural';
import { t } from '../../i18n';
import { sourceToPodcastSchema } from '../../lib/seo/jsonld';

export async function getStaticPaths() {
  const sources = await getCollection('sources');
  return sources.map((source) => ({
    params: { source: source.id },
    props: { source },
  }));
}

const { source } = Astro.props;
const data = source.data;

// Recos de cette source (les « discarded » sont masquées du public).
// Les citations (kind=citation) restent visibles dans le catalogue avec leur
// badge « Mentionné », mais ne comptent pas dans le compteur principal.
// DÉCISION PRODUIT (CR Story 4) : les œuvres d'invité·es (`guestWork`) restent
// kind=reco et sont donc INCLUSES ici dans `trueRecos` et tous les compteurs —
// seule la page épisode les présente dans une sous-section séparée.
const recos = (await getCollection('recos'))
  .filter((r) => r.data.sourceId.id === source.id && r.data.status !== 'discarded')
  .map((r) => r.data);
const trueRecos = recos.filter((r) => r.kind !== 'citation');

// Épisodes indexés par guid pour afficher le numéro/titre sur les cartes.
const episodes = (await getCollection('episodes')).filter(
  (e) => e.data.sourceId.id === source.id,
);
const epByGuid = new Map(episodes.map((e) => [e.data.guid, e.data]));

// Types présents (pour les filtres), triés par fréquence.
const counts = new Map<string, number>();
// Une reco multi-types compte dans chaque type (le filtre est inclusif).
for (const r of recos) for (const t of r.types) counts.set(t, (counts.get(t) ?? 0) + 1);
const types = [...counts.entries()].sort((a, b) => b[1] - a[1]);

// Vue « par épisode » : épisodes ayant ≥1 reco, du plus récent au plus ancien.
// On compte seulement les vraies recos (pas les citations) pour rester cohérent
// avec le compteur global affiché plus haut.
const recoCountByEp = new Map<string, number>();
for (const r of trueRecos)
  recoCountByEp.set(r.episodeGuid, (recoCountByEp.get(r.episodeGuid) ?? 0) + 1);
const episodesWithRecos = episodes
  .map((e) => e.data)
  .filter((e) => recoCountByEp.has(e.guid))
  .sort((a, b) => (b.date?.getTime() ?? 0) - (a.date?.getTime() ?? 0));

const ytThumb = (url?: string) => {
  const id = url?.match(/[?&]v=([\w-]+)/)?.[1];
  return id ? `https://i.ytimg.com/vi/${id}/mqdefault.jpg` : null;
};
const epLabel = episodeLabel;

// JSON-LD : PodcastSeries + BreadcrumbList (Accueil → Source).
// Cf. ADR 0021 §7 et ADR 0027 (mapping schema.org).
const sourceUrl = new URL(`/${source.id}`, Astro.site).toString();
const homeUrl = new URL('/', Astro.site).toString();
const podcastSchema = sourceToPodcastSchema({
  id: source.id,
  title: data.title,
  description: data.description,
  url: sourceUrl,
  rssUrl: data.rssUrl,
});
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: homeUrl },
    { '@type': 'ListItem', position: 2, name: data.title, item: sourceUrl },
  ],
};
const jsonLd = [podcastSchema, breadcrumb];
---

<Layout
  title={`${data.title} — recommandations`}
  description={data.description ?? `${trueRecos.length} ${plural(trueRecos.length, 'recommandation')} ${plural(trueRecos.length, 'extraite')} des ${episodesWithRecos.length} ${plural(episodesWithRecos.length, 'épisode')} du podcast ${data.title}.`}
  theme={data.theme}
  ogSlug={source.id}
  jsonLd={jsonLd}
>
  <header class="head wrap" role="banner">
    <a class="back" href="/">
      <span aria-hidden="true">←</span> <span>{t('nav.backHome')}</span>
    </a>
    <h1>{data.title}</h1>
    {data.tagline && <p class="tag">{data.tagline}</p>}
    <p class="stat">
      {trueRecos.length} {plural(trueRecos.length, 'recommandation')}
      <span aria-hidden="true">·</span>
      <a class="review-link" href={`/${source.id}/verifier`}>vérifier</a>
    </p>
  </header>

  {/* C1/C5 : <main id="main"> enveloppe les 2 tabpanels ET la toolbar.
     Le skip-link cible bien le vrai <main>. */}
  <main id="main">
    <nav class="tabs wrap" aria-label={t('nav.tabsLabel')}>
      <div
        role="tablist"
        aria-label={t('nav.tabsLabel')}
        aria-orientation="horizontal"
        class="tablist"
      >
        <button
          class="tab is-active"
          data-view="episodes"
          role="tab"
          id="tab-episodes"
          aria-selected="true"
          aria-controls="view-episodes"
          tabindex="0"
        >
          Par épisode
        </button>
        <button
          class="tab"
          data-view="all"
          role="tab"
          id="tab-all"
          aria-selected="false"
          aria-controls="view-all"
          tabindex="-1"
        >
          Toutes les recos
        </button>
      </div>
    </nav>

    {/* Vue 1 : toutes les recos (recherche + filtres) */}
    <section id="view-all" role="tabpanel" aria-labelledby="tab-all" hidden>
      <div class="toolbar wrap">
        <input
          id="search"
          class="search"
          type="search"
          placeholder="Rechercher un titre, un auteur…"
          autocomplete="off"
          aria-label="Rechercher une recommandation"
        />
        <div class="filters" role="group" aria-label="Filtrer par type">
          <button class="chip is-active" data-filter="all" aria-pressed="true">
            Tout
          </button>
          {
            types.map(([typ, n]) => (
              <button class="chip" data-filter={typ} aria-pressed="false">
                {TYPE_LABELS_PLURAL[typ] ?? typ} <span class="n">{n}</span>
              </button>
            ))
          }
        </div>
      </div>

      <div class="wrap">
        <h2 class="visually-hidden">Toutes les recommandations</h2>
        {
          recos.length === 0 ? (
            <EmptyState
              message="Pas encore de recommandation."
              hint="Lance le pipeline (voir tools/README.md) pour les importer."
            />
          ) : (
            <ul class="grid" id="reco-grid" aria-label="Recommandations">
              {recos.map((r) => (
                <RecoCard
                  reco={r}
                  episodeNumber={epByGuid.get(r.episodeGuid)?.number}
                  episodeTitle={epByGuid.get(r.episodeGuid)?.title}
                  sourceId={source.id}
                />
              ))}
            </ul>
          )
        }
        {/* C7 : élément TOUJOURS présent et accessible (pas clippé). On
           toggle le `.textContent` plutôt que la visibilité, garantissant
           que `aria-live="polite"` annoncera le changement. */}
        <p
          class="noresult"
          id="noresult"
          role="status"
          aria-live="polite"
          aria-atomic="true"
        ></p>
      </div>
    </section>

    {/* Vue 2 : par épisode (miniatures, plus récent d'abord) — vue par défaut */}
    <section id="view-episodes" role="tabpanel" aria-labelledby="tab-episodes">
      <div class="toolbar wrap">
        <input
          id="ep-search"
          class="search"
          type="search"
          placeholder="Rechercher un épisode ou un invité…"
          autocomplete="off"
          aria-label="Rechercher un épisode"
        />
        <span class="ep-count">
          <span id="ep-visible">{episodesWithRecos.length}</span> épisodes
        </span>
      </div>

      <div class="wrap">
        {/* C6 : heading explicite pour respecter la hiérarchie h1→h2. */}
        <h2 class="visually-hidden">{t('heading.episodesWithRecos')}</h2>
        <ul class="ep-grid" id="ep-grid" aria-label="Épisodes avec recommandations">
          {
            episodesWithRecos.map((e) => {
              const thumb = ytThumb(e.youtubeUrl);
              const epTitle = e.youtubeTitle ?? e.title;
              const epLabelStr = epLabel(e);
              // Normalisation SSR (sans accents + lowercase) pour la recherche
              // tolérante côté client. Cf. helper fuzzyMatch() dans le <script>.
              const searchKey = `${epTitle} ${epLabelStr} ${e.title}`
                .normalize('NFD')
                .replace(/[̀-ͯ]/g, '')
                .toLowerCase();
              // H13 : l'étiquette accessible du lien inclut le numéro
              // (info visuelle « S1·E12 » désormais portée par aria-label).
              const accLabel = epLabelStr
                ? `${epLabelStr} — ${epTitle}`
                : epTitle;
              return (
                <li class="ep-card" data-search={searchKey}>
                  <a href={`/${source.id}/episode/${e.guid}`} aria-label={accLabel}>
                    <div class="ep-thumb">
                      {thumb && (
                        <img
                          src={thumb}
                          alt=""
                          loading="lazy"
                          decoding="async"
                          width="320"
                          height="180"
                        />
                      )}
                      {epLabelStr && (
                        <span class="ep-badge" aria-hidden="true">{epLabelStr}</span>
                      )}
                    </div>
                    <div class="ep-meta">
                      <h3 class="ep-ttl">{epTitle}</h3>
                      <span class="ep-cnt">{recoCountByEp.get(e.guid)} recos</span>
                    </div>
                  </a>
                </li>
              );
            })
          }
        </ul>
        <p
          class="noresult"
          id="ep-noresult"
          role="status"
          aria-live="polite"
          aria-atomic="true"
        ></p>
      </div>
    </section>
  </main>
</Layout>

<script>
  // Helpers de recherche tolérante (normalize / levenshtein / fuzzyMatch)
  // partagés via src/utils/search.ts pour éviter la duplication entre pages.
  import { fuzzyMatch } from '../../utils/search';

  // --- Filtrage 100 % client : par type (chips) et par texte (fuzzy) -------
  const grid = document.getElementById('reco-grid');
  const search = document.getElementById('search') as HTMLInputElement | null;
  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.chip'));
  const noresult = document.getElementById('noresult');

  let activeType = 'all';
  let term = '';

  function apply() {
    if (!grid) return;
    const cards = Array.from(grid.children) as HTMLElement[];
    let visible = 0;
    for (const card of cards) {
      const okType =
        activeType === 'all' ||
        (card.dataset.types?.split(',').includes(activeType) ?? false);
      const okText = !term || fuzzyMatch(term, card.dataset.search ?? '');
      const show = okType && okText;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    }
    // C7 : on change le `textContent`, l'élément reste TOUJOURS dans le DOM
    // accessible. Ainsi `aria-live="polite"` notifie effectivement les AT.
    if (noresult) noresult.textContent = visible === 0 ? 'Aucun résultat.' : '';
  }

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      activeType = chip.dataset.filter ?? 'all';
      chips.forEach((c) => {
        const on = c === chip;
        c.classList.toggle('is-active', on);
        c.setAttribute('aria-pressed', String(on));
      });
      apply();
    });
  });

  search?.addEventListener('input', () => {
    term = search.value;
    apply();
  });

  // Bascule entre « Toutes les recos » et « Par épisode ».
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.tab'));
  const views: Record<string, HTMLElement | null> = {
    all: document.getElementById('view-all'),
    episodes: document.getElementById('view-episodes'),
  };
  function activateTab(tab: HTMLButtonElement) {
    const view = tab.dataset.view ?? 'all';
    tabs.forEach((t) => {
      const on = t === tab;
      t.classList.toggle('is-active', on);
      t.setAttribute('aria-selected', String(on));
      // Roving tabindex (WAI-ARIA Authoring Practices) : seul l'onglet actif
      // est dans l'ordre Tab. Les flèches naviguent entre les onglets.
      t.setAttribute('tabindex', on ? '0' : '-1');
    });
    for (const [key, el] of Object.entries(views)) {
      if (el) el.hidden = key !== view;
    }
  }
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => activateTab(tab));
    tab.addEventListener('keydown', (e: KeyboardEvent) => {
      const idx = tabs.indexOf(tab);
      let next = -1;
      if (e.key === 'ArrowRight') next = (idx + 1) % tabs.length;
      else if (e.key === 'ArrowLeft') next = (idx - 1 + tabs.length) % tabs.length;
      else if (e.key === 'Home') next = 0;
      else if (e.key === 'End') next = tabs.length - 1;
      // C4 : Space/Enter activent l'onglet focusé (redondant via <button>
      // natif, mais explicite pour le mode « automatic activation »).
      else if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        activateTab(tab);
        return;
      }
      if (next >= 0) {
        e.preventDefault();
        activateTab(tabs[next]);
        tabs[next].focus();
      }
    });
  });

  // --- Recherche dans la vue « Par épisode » -------------------------------
  const epGrid = document.getElementById('ep-grid');
  const epSearch = document.getElementById('ep-search') as HTMLInputElement | null;
  const epVisible = document.getElementById('ep-visible');
  const epNoresult = document.getElementById('ep-noresult');
  epSearch?.addEventListener('input', () => {
    if (!epGrid) return;
    const q = epSearch.value;
    let count = 0;
    for (const card of Array.from(epGrid.children) as HTMLElement[]) {
      const show = !q.trim() || fuzzyMatch(q, card.dataset.search ?? '');
      card.style.display = show ? '' : 'none';
      if (show) count++;
    }
    if (epVisible) epVisible.textContent = String(count);
    if (epNoresult) epNoresult.textContent = count === 0 ? 'Aucun épisode trouvé.' : '';
  });

  // Le lazy-load des miniatures utilise désormais l'attribut natif
  // `loading="lazy"` sur les <img> rendues côté SSR (meilleure a11y :
  // l'image vit dans le DOM avec son texte alternatif, et le navigateur
  // gère la priorité de chargement).
</script>

<style>
  .head {
    padding: clamp(2rem, 6vw, 4rem) 0 1.5rem;
  }
  .back {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
  }
  .back:hover {
    color: var(--accent);
  }
  .head h1 {
    font-size: clamp(2.6rem, 9vw, 6.5rem);
    margin: 0.6rem 0 0.3rem;
  }
  .tag {
    color: var(--text);
    margin: 0;
  }
  .stat {
    color: var(--muted);
    margin: 0.3rem 0 0;
    font-size: 0.85rem;
  }
  .review-link {
    color: var(--muted);
    text-decoration: none;
  }
  .review-link:hover {
    color: var(--accent);
  }
  /* Onglets de vue */
  .tabs {
    margin: 0.4rem auto 0;
  }
  .tablist {
    display: flex;
    gap: 0.5rem;
  }
  .tab {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    background: transparent;
    /* Contraste WCAG AA : on utilise text+opacity au lieu de --muted brut
       pour garantir un ratio ≥4.5:1 sur fond --bg (texte d'onglet inactif
       reste lisible). */
    color: color-mix(in oklab, var(--text) 78%, transparent);
    border: 1px solid color-mix(in oklab, var(--text) 30%, transparent);
    border-radius: 999px;
    padding: 0.45em 1.1em;
    /* L20 : Firefox parfois ne met pas cursor:pointer sur <button>. */
    cursor: pointer;
    transition: all 0.16s ease;
  }
  .tab:hover {
    color: var(--text);
  }
  .tab.is-active {
    background: var(--accent);
    color: var(--accent-text);
    border-color: var(--accent);
  }
  .ep-count {
    color: var(--muted);
    font-size: 0.85rem;
    white-space: nowrap;
  }
  /* Grille « par épisode » */
  .ep-grid {
    list-style: none;
    padding: 0;
    margin: 0 0 4rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 240px), 1fr));
    gap: var(--gap);
  }
  .ep-card a {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .ep-thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    background: var(--surface);
    overflow: hidden;
    border: 1px solid color-mix(in oklab, var(--text) 8%, transparent);
    transition:
      transform 0.2s cubic-bezier(0.2, 0.7, 0.2, 1),
      border-color 0.2s ease;
  }
  .ep-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ep-card a:hover .ep-thumb {
    transform: translateY(-4px);
    border-color: var(--accent);
  }
  .ep-badge {
    position: absolute;
    top: 0;
    left: 0;
    background: color-mix(in oklab, var(--bg) 78%, transparent);
    color: var(--accent);
    font-weight: 700;
    font-size: 0.75rem;
    padding: 0.2em 0.6em;
    border-radius: var(--radius) 0 8px 0;
  }
  .ep-meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.5rem 0.2rem 0;
  }
  /* C6 : le titre d'épisode est un <h3> (h1 source → h2 sections → h3 cards). */
  .ep-ttl {
    font-family: var(--font-body);
    text-transform: none;
    letter-spacing: normal;
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.25;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .ep-cnt {
    color: var(--muted);
    font-size: 0.8rem;
  }
  .toolbar {
    position: sticky;
    top: 0;
    z-index: 5;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    align-items: center;
    padding: 0.9rem 0;
    margin-bottom: 1.4rem;
    background: color-mix(in oklab, var(--bg) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid color-mix(in oklab, var(--text) 8%, transparent);
  }
  /* P2-3 : on supprime les `.search:focus-visible` / `.link:focus-visible`
     redondants — la règle globale `:where(...):focus-visible` (CSS contract)
     prend en charge avec halo + outline-offset. */
  .search {
    flex: 1 1 240px;
    min-width: 200px;
    background: var(--surface);
    border: 1px solid color-mix(in oklab, var(--text) 14%, transparent);
    color: var(--text);
    border-radius: 999px;
    padding: 0.6em 1em;
    font: inherit;
  }
  /* M9 : placeholder color : on garantit le contraste minimal (3:1)
     même sur fond --surface (les browsers appliquent souvent 50% opacity). */
  .search::placeholder {
    color: color-mix(in oklab, var(--text) 62%, transparent);
    opacity: 1;
  }
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .n {
    opacity: 0.6;
    font-size: 0.78em;
  }
  /* C7 : `.noresult` n'est PLUS clippé (`visually-hidden`) — il est vide
     par défaut et reçoit du texte uniquement quand 0 résultat, ce qui
     déclenche l'annonce `aria-live="polite"`. */
  .noresult {
    color: var(--muted);
    padding: 2rem 0 4rem;
    min-height: 1.5em;
    margin: 0;
  }
  main {
    padding-bottom: 4rem;
  }
</style>
