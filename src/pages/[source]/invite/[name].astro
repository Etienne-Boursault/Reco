---
/**
 * /[source]/invite/[name] — Toutes les recos d'un invité dans une source.
 *
 * Source des noms d'invités : champ `recommendedBy` des mentions publiques,
 * dédupliqué + slugifié pour produire l'URL. Cf. ADR 0031.
 *
 * NB : on n'utilise PAS `episodes.guests_parsed` ici car la roadmap dit
 * « toutes les recommandations d'un invité » → on filtre sur qui a fait
 * la reco, pas sur qui était invité à l'épisode (deux invités peuvent
 * coexister, seul celui qui a parlé compte pour la galerie individuelle).
 */
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import GalleryGrid from '../../../components/GalleryGrid.astro';
import { listGuests, selectByGuest } from '../../../lib/gallery/aggregate';
import { buildGuestIndex } from '../../../lib/gallery/slug';
import { galleryBreadcrumb, galleryItemListSchema } from '../../../lib/gallery/page';
import { t } from '../../../i18n';

export async function getStaticPaths() {
  const sources = await getCollection('sources');
  const allMentions = await getCollection('mentions');
  const paths: Array<{
    params: { source: string; name: string };
    props: { source: (typeof sources)[number]; guestName: string };
  }> = [];
  for (const source of sources) {
    const mentions = allMentions
      .filter((m) => m.data.sourceRef.sourceId === source.id)
      .map((m) => m.data);
    const hosts = source.data.hosts ?? [];
    const guestNames = listGuests(mentions, hosts);
    const index = buildGuestIndex(guestNames);
    for (const [slug, guestName] of index) {
      paths.push({
        params: { source: source.id, name: slug },
        props: { source, guestName },
      });
    }
  }
  return paths;
}

const { source, guestName } = Astro.props;
const data = source.data;

const mentions = (await getCollection('mentions'))
  .filter((m) => m.data.sourceRef.sourceId === source.id)
  .map((m) => m.data);
const mentionedIds = new Set(mentions.map((m) => m.itemId));
const items = (await getCollection('items'))
  .map((i) => i.data)
  .filter((it) => mentionedIds.has(it.id));

const entries = selectByGuest(items, mentions, guestName);

const heading = `${t('gallery.guest.titlePrefix')} ${guestName}`;
const countLabel = 'recommandations';
const description = `${entries.length} recommandations de ${guestName} dans ${data.title}.`;

const sourceUrl = new URL(`/${source.id}`, Astro.site).toString();
const homeUrl = new URL('/', Astro.site).toString();
const slug = Astro.params.name;
const galleryUrl = new URL(`/${source.id}/invite/${slug}`, Astro.site).toString();

const jsonLd = [
  galleryItemListSchema(entries, { name: heading, description }),
  galleryBreadcrumb({
    homeUrl,
    sourceName: data.title,
    sourceUrl,
    galleryName: guestName,
    galleryUrl,
  }),
];
---

<Layout
  title={`${heading} — ${data.title}`}
  description={description}
  theme={data.theme}
  ogSlug={source.id}
  jsonLd={jsonLd}
>
  <header class="head wrap" role="banner">
    <a class="back" href={`/${source.id}`}>
      <span aria-hidden="true">←</span> <span>{t('gallery.backToSource')} {data.title}</span>
    </a>
    <h1>{heading}</h1>
    <p class="tag">Toutes les œuvres recommandées par <strong>{guestName}</strong> dans <strong>{data.title}</strong>.</p>
  </header>
  <main id="main" class="wrap">
    <h2 class="visually-hidden">Liste des recommandations de {guestName}</h2>
    <GalleryGrid
      heading={heading}
      entries={entries}
      countLabel={countLabel}
      emptyMessage="Pas encore de recommandation pour cet invité."
      sourceId={source.id}
    />
  </main>
</Layout>

<style>
  .head { padding: clamp(2rem, 6vw, 4rem) 0 1.5rem; }
  .back { color: var(--muted); text-decoration: none; font-size: 0.85rem; font-weight: 600; }
  .back:hover { color: var(--accent); }
  .head h1 { font-size: clamp(2.2rem, 7vw, 5rem); margin: 0.6rem 0 0.3rem; }
  .tag { color: var(--text); margin: 0 0 0.5rem; }
  main { padding-bottom: 4rem; }
  .visually-hidden { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
</style>
