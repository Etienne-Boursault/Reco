---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import RecoCard from '../../../components/RecoCard.astro';
import { episodeLabel } from '../../../utils/recoTypes';

export async function getStaticPaths() {
  const sources = await getCollection('sources');
  const recos = await getCollection('recos');
  const episodes = await getCollection('episodes');

  const paths = [];
  for (const source of sources) {
    const sRecos = recos.filter(
      (r) => r.data.sourceId.id === source.id && r.data.status !== 'discarded',
    );
    const guidsWithRecos = new Set(sRecos.map((r) => r.data.episodeGuid));
    // Épisodes triés (saison, numéro) pour calculer prev/next stables.
    const sEpisodes = episodes
      .filter(
        (e) => e.data.sourceId.id === source.id && guidsWithRecos.has(e.data.guid),
      )
      .sort((a, b) => {
        const sa = a.data.season ?? 0;
        const sb = b.data.season ?? 0;
        if (sa !== sb) return sa - sb;
        return (a.data.number ?? 9999) - (b.data.number ?? 9999);
      });
    for (let i = 0; i < sEpisodes.length; i++) {
      const episode = sEpisodes[i];
      const prev = sEpisodes[i - 1];
      const next = sEpisodes[i + 1];
      paths.push({
        params: { source: source.id, guid: episode.data.guid },
        props: {
          source,
          episode: episode.data,
          prevGuid: prev?.data.guid ?? null,
          nextGuid: next?.data.guid ?? null,
          recos: sRecos
            .filter((r) => r.data.episodeGuid === episode.data.guid)
            .map((r) => r.data),
        },
      });
    }
  }
  return paths;
}

const { source, episode, recos, prevGuid, nextGuid } = Astro.props;
const data = source.data;

const ytId = episode.youtubeUrl?.match(/[?&]v=([\w-]+)/)?.[1];
const thumb = ytId ? `https://i.ytimg.com/vi/${ytId}/hqdefault.jpg` : null;
const epNum = episodeLabel(episode);
const epTitle = episode.youtubeTitle ?? episode.title;
---

<Layout
  title={`${epTitle} — ${data.title}`}
  description={`${recos.length} recommandations extraites de ${epTitle}, épisode du podcast ${data.title}.`}
  ogImage={thumb ?? undefined}
  ogType="article"
  theme={data.theme}
>
  <header class="head wrap">
    <a class="back" href={`/${source.id}`}>← {data.title}</a>
    <div class="ep-nav">
      {prevGuid ? (
        <a class="ep-arrow ep-arrow-prev" href={`/${source.id}/episode/${prevGuid}`}
           title="Épisode précédent" aria-label="Épisode précédent">‹</a>
      ) : (
        <span class="ep-arrow disabled" aria-hidden="true">‹</span>
      )}
      <div class="ep-hero">
        {
          episode.youtubeUrl ? (
            <a class="thumb" href={episode.youtubeUrl} target="_blank" rel="noopener noreferrer">
              {thumb && <img src={thumb} alt={epTitle} loading="lazy" />}
              <span class="play">▶</span>
            </a>
          ) : (
            thumb && <img class="thumb" src={thumb} alt={epTitle} loading="lazy" />
          )
        }
        <div class="ep-info">
          {epNum && <span class="epnum">{epNum}</span>}
          <h1>{epTitle}</h1>
          <p class="count">{recos.length} recommandation{recos.length > 1 ? 's' : ''}</p>
        </div>
      </div>
      {nextGuid ? (
        <a class="ep-arrow ep-arrow-next" href={`/${source.id}/episode/${nextGuid}`}
           title="Épisode suivant" aria-label="Épisode suivant">›</a>
      ) : (
        <span class="ep-arrow disabled" aria-hidden="true">›</span>
      )}
    </div>
  </header>

  <main class="wrap">
    <ul class="grid">
      {
        recos.map((r) => (
          <RecoCard
            reco={r}
            episodeNumber={episode.number}
            episodeTitle={epTitle}
          />
        ))
      }
    </ul>
  </main>
</Layout>

<style>
  .head {
    padding: clamp(1.5rem, 4vw, 2.5rem) 0 1.5rem;
  }
  .back {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
  }
  .back:hover {
    color: var(--accent);
  }
  .ep-nav {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1rem;
  }
  .ep-hero {
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    align-items: center;
  }
  .ep-arrow {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: var(--surface);
    border: 1px solid color-mix(in oklab, var(--text) 14%, transparent);
    color: var(--text);
    text-decoration: none;
    font-size: 1.8rem;
    line-height: 1;
    transition: border-color 0.16s ease, color 0.16s ease, background 0.16s ease;
  }
  .ep-arrow:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: color-mix(in oklab, var(--accent) 12%, transparent);
  }
  .ep-arrow.disabled {
    opacity: 0.25;
    cursor: default;
  }
  .thumb {
    position: relative;
    flex: 0 0 auto;
    width: min(100%, 360px);
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface);
    display: block;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-size: 2.5rem;
    color: #fff;
    background: rgba(0, 0, 0, 0.25);
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  a.thumb:hover .play {
    opacity: 1;
  }
  .ep-info {
    flex: 1 1 280px;
  }
  .epnum {
    color: var(--accent);
    font-weight: 700;
    font-size: 0.85rem;
  }
  .ep-info h1 {
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    margin: 0.3rem 0;
  }
  .count {
    color: var(--muted);
    margin: 0;
  }
  main {
    padding-bottom: 4rem;
  }
</style>
