---
/**
 * /stats — Statistiques publiques globales (item #26 / ADR 0047).
 *
 * Build-time : agrège items + mentions + episodes via
 * `src/lib/stats/aggregator.ts` (pures fonctions, idempotentes). Pas de
 * lib charting — SVG inline minimal. A11y WCAG AA (table sémantique,
 * landmarks). JSON-LD `Dataset` schema.org enrichi.
 *
 * Issues fixées :
 *  - R-P1-24 : tente d'abord le sidecar `tools/output/stats/_global/stats.json`
 *    (pattern pré-calculé ADR 0020 pour scaling 100k recos). Fallback
 *    compute si absent — comportement par défaut local / dev.
 *  - M26-14 : suppression du `role="banner"` redondant sur `<header>` (rôle
 *    implicite ARIA 1.2 lorsqu'il est en descendant direct de `<body>`).
 *  - M26-16 : JSON-LD enrichi (keywords, license, publisher,
 *    temporalCoverage).
 *  - M26-17 : `distributionUrl` pointe vers `/stats.json`.
 *  - M26-18 : `publisher` lu depuis `siteConfig` (ADR 0028).
 *  - M26-20 : `generatedLocal` via `Intl.DateTimeFormat('fr-FR', …)` —
 *    locale fixée côté build (pas `toLocaleDateString` qui dépend de
 *    l'env Node).
 *  - R-P2-28 : note `stats.typeDistribution.note` rappelant que seul le
 *    type primaire est compté.
 */
// F-M-17 — `node:fs` synchrone volontaire : ce code tourne **au build**
// Astro (pas en runtime serveur), où la lecture sidecar bloque < 1 ms et
// `fs/promises` ajouterait un `await` sans gain (le frontmatter Astro est
// déjà top-level async). Cohérent avec la version `/[source]/stats.astro`.
import { existsSync, readFileSync } from 'node:fs';
import { join } from 'node:path';
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import StatCard from '../components/StatCard.astro';

// F-CRIT-3 — page statique générée au build.
export const prerender = true;
import TopList from '../components/TopList.astro';
import StatChart from '../components/StatChart.astro';
import { t } from '../i18n';
import { loadStatsForPage } from '../lib/stats/page';
import { statsSnapshotSchema, type StatsSnapshot } from '../lib/stats/types';
import { siteConfig } from '../config/site';
// F-M-4 : mapping de type brut → libellé pluriel (« film » → « Films »)
// pour distributionBars et `topWorks.sub`. Centralisé via `recoTypes` pour
// rester cohérent avec les cartes catalogue.
import { TYPE_LABELS, TYPE_LABELS_PLURAL } from '../utils/recoTypes';

const SIDECAR_PATH = join(process.cwd(), 'tools', 'output', 'stats', '_global', 'stats.json');

/** Lecture sidecar pré-calculé (cf. R-P1-24). Retourne null si absent / invalide. */
function readSidecar(): StatsSnapshot | null {
  try {
    if (!existsSync(SIDECAR_PATH)) return null;
    const raw = JSON.parse(readFileSync(SIDECAR_PATH, 'utf-8'));
    return statsSnapshotSchema.parse(raw);
  } catch {
    return null;
  }
}

const sidecar = readSidecar();
const collections = sidecar
  ? { sources: [], episodes: [], mentions: [], items: [] }
  : {
      sources: (await getCollection('sources')).map((s) => ({
        id: s.id,
        hosts: s.data.hosts ?? [],
      })),
      episodes: (await getCollection('episodes')).map((e) => ({
        sourceId: e.data.sourceId.id,
        date: e.data.date ?? null,
      })),
      mentions: (await getCollection('mentions')).map((m) => ({
        itemId: m.data.itemId,
        recommendedBy: m.data.recommendedBy ?? null,
        status: m.data.status,
        sourceRef: { sourceId: m.data.sourceRef.sourceId },
      })),
      items: (await getCollection('items')).map((i) => ({
        id: i.data.id,
        title: i.data.title,
        types: i.data.types,
      })),
    };

const {
  snapshot,
  generatedLocal,
  topGuests,
  topWorks: topWorksRaw,
  distributionBars: distributionBarsRaw,
  monthlyBars,
  jsonLd,
} = loadStatsForPage({
  sidecar,
  collections,
  pageUrl: new URL('/stats', Astro.site).toString(),
  distributionUrl: new URL('/stats.json', Astro.site).toString(),
  datasetName: t('stats.title'),
  datasetDescription: t('stats.dataset.description'),
  publisher: { name: siteConfig.siteName },
});

// F-M-4 : map labels bruts → libellés humains (sinon affichage de clés
// type « film », « serie » dans le chart et la sub-row du top).
const distributionBars = distributionBarsRaw.map((b) => ({
  ...b,
  label: TYPE_LABELS_PLURAL[b.label] ?? b.label,
}));
const topWorks = topWorksRaw.map((w) => ({
  ...w,
  sub: w.sub ? (TYPE_LABELS[w.sub] ?? w.sub) : w.sub,
}));
---

<Layout
  title={t('stats.metaTitle')}
  description={t('stats.subtitle')}
  jsonLd={jsonLd}
>
  <header class="hero wrap">
    <h1>{t('stats.title')}</h1>
    <p class="lede">{t('stats.subtitle')}</p>
    <p class="generated">
      {t('stats.generatedAt', { date: generatedLocal })}
    </p>
  </header>

  <main id="main" class="wrap">
    <section aria-labelledby="global">
      <h2 id="global">{t('stats.heading.global')}</h2>
      <div class="cards">
        <StatCard value={snapshot.global.podcastsCount} label={t('stats.card.podcasts')} />
        <StatCard value={snapshot.global.episodesCount} label={t('stats.card.episodes')} />
        <StatCard value={snapshot.global.recommendationsCount} label={t('stats.card.recommendations')} />
        <StatCard value={snapshot.global.uniqueWorksCount} label={t('stats.card.uniqueWorks')} />
        <StatCard value={snapshot.global.uniqueGuestsCount} label={t('stats.card.uniqueGuests')} />
      </div>
    </section>

    <section aria-labelledby="top-guests">
      <h2 id="top-guests">{t('stats.heading.topGuests')}</h2>
      <TopList
        caption={t('stats.heading.topGuests')}
        rows={topGuests}
        countHeader={t('stats.col.mentions')}
        emptyMessage={t('stats.empty.topGuests')}
      />
    </section>

    <section aria-labelledby="top-works">
      <h2 id="top-works">{t('stats.heading.topWorks')}</h2>
      <TopList
        caption={t('stats.heading.topWorks')}
        rows={topWorks}
        countHeader={t('stats.col.mentions')}
        emptyMessage={t('stats.empty.topWorks')}
      />
    </section>

    <section aria-labelledby="dist">
      <h2 id="dist">{t('stats.heading.typeDistribution')}</h2>
      <StatChart
        title={t('stats.heading.typeDistribution')}
        bars={distributionBars}
        valueHeader={t('stats.col.mentions')}
        emptyKey="stats.empty.typeDistribution"
      />
      <p class="note muted">{t('stats.typeDistribution.note')}</p>
    </section>

    <section aria-labelledby="monthly">
      <h2 id="monthly">{t('stats.heading.monthly')}</h2>
      <StatChart
        title={t('stats.heading.monthly')}
        bars={monthlyBars}
        valueHeader={t('stats.col.episodes')}
        emptyKey="stats.empty.monthly"
      />
    </section>

    <p class="privacy muted">{t('stats.privacyNote')}</p>
  </main>
</Layout>

<style>
  .hero {
    padding: clamp(2rem, 6vw, 4rem) 0 1.5rem;
  }
  .hero h1 {
    font-size: clamp(2.2rem, 6vw, 4rem);
    margin: 0 0 0.6rem;
  }
  .lede {
    color: var(--muted);
    max-width: 60ch;
    margin: 0 0 0.4rem;
  }
  .generated {
    color: var(--muted);
    font-size: 0.85rem;
    margin: 0;
  }
  main {
    padding-bottom: 4rem;
  }
  main section {
    margin: 2.2rem 0;
  }
  main h2 {
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    margin: 0 0 1rem;
  }
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }
  .note {
    font-size: 0.85rem;
    margin: 0.4rem 0 0;
  }
  .privacy {
    margin-top: 3rem;
    font-size: 0.85rem;
  }
  .muted { color: var(--muted); }
</style>
