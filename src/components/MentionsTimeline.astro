---
/**
 * MentionsTimeline — liste chronologique des épisodes où une œuvre est
 * citée. Chaque entrée : titre épisode (lien), date, recommandedBy, quote
 * et timestamp YouTube cliquable si applicable.
 *
 * A11y :
 *  - `<ol>` ordonné (sémantique de séquence temporelle).
 *  - `<time datetime>` sur les dates.
 *  - Liens externes marqués via le pattern global `a11y.externalLinkSuffix`.
 */
import type { JoinedMention } from '../lib/work/aggregator';
import { youtubeDeepLink } from '../lib/work/aggregator';
import { episodeLabel } from '../utils/recoTypes';
import { t } from '../i18n';
import {
  extractYoutubeId,
  parseTimecode,
} from '../lib/audio/timecode';
import AudioExcerpt from './AudioExcerpt.astro';
import OutboundLink from './OutboundLink.astro';

interface Props {
  sourceId: string;
  mentions: JoinedMention[];
}
const { sourceId, mentions } = Astro.props;

function fmtDate(d?: Date): string {
  if (!d || !(d instanceof Date) || Number.isNaN(d.getTime())) return '';
  return d.toLocaleDateString('fr-FR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<ol class="timeline">
  {mentions.map((jm) => {
    const ep = jm.episode;
    const m = jm.mention;
    const ytLink = youtubeDeepLink(jm);
    const isCitation = m.kind === 'citation';
    const isGuestWork = m.guestWork === true;
    // Item #12 : extrait audio inline.
    // L'offset n'est légitime que si le timestamp vient de YouTube (cf.
    // politique transcripts : pas d'offset entre YT et Acast).
    const ytId = extractYoutubeId(ep?.youtubeUrl ?? null);
    const startSeconds =
      m.sourceRef.transcriptSource === 'youtube'
        ? parseTimecode(m.sourceRef.timestamp ?? null) ?? 0
        : 0;
    return (
      <li class:list={['tl-item', { 'tl-citation': isCitation }]}>
        <div class="tl-head">
          {ep ? (
            <a class="tl-ep" href={`/${sourceId}/episode/${ep.guid}`}>
              {episodeLabel(ep) && <span class="tl-epnum">{episodeLabel(ep)}</span>}
              <span class="tl-eptitle">{ep.youtubeTitle ?? ep.title}</span>
            </a>
          ) : (
            <span class="tl-eptitle tl-eptitle-orphan">{t('work.mentions.unknownEpisode')}</span>
          )}
          {ep?.date && (
            <time class="tl-date" datetime={ep.date.toISOString()}>
              {fmtDate(ep.date)}
            </time>
          )}
        </div>

        <div class="tl-meta">
          {isGuestWork && (
            <span class="tl-guestwork" aria-label={t('reco.guestWork.badgeA11y')}>
              {/* M3 : ⭐ — cf. RecoCard, évite la collision avec l'emoji du
                 type « artiste » (🎤). */}
              <span aria-hidden="true">⭐</span> {t('reco.guestWork.badge')}
            </span>
          )}
          {m.recommendedBy && (
            <span class="tl-by">
              {isCitation ? t('work.mentions.byCitation') : t('work.mentions.byReco')} {m.recommendedBy}
            </span>
          )}
          {ytLink && (
            <OutboundLink
              class="tl-ts"
              href={ytLink}
              category="youtube"
              sourceId={sourceId}
              recoId={m.id}
              ariaLabel={`${t('work.mentions.youtubeA11y')} ${t('a11y.externalLinkSuffix')}`}
            >
              <span aria-hidden="true">▶</span>
              {m.sourceRef.timestamp ?? t('work.mentions.youtubeFallback')}
            </OutboundLink>
          )}
        </div>

        {m.quote && <blockquote class="tl-quote">« {m.quote} »</blockquote>}

        {ytId && startSeconds > 0 && (
          <div class="tl-audio">
            <AudioExcerpt
              youtubeId={ytId}
              startSeconds={startSeconds}
              id={m.id}
              title={ep ? (ep.youtubeTitle ?? ep.title) : undefined}
            />
          </div>
        )}
      </li>
    );
  })}
</ol>

<style>
  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .tl-item {
    background: var(--surface);
    border: 1px solid color-mix(in oklab, var(--text) 8%, transparent);
    border-radius: var(--radius);
    padding: 0.9rem 1rem;
    border-left: 3px solid var(--accent);
  }
  .tl-citation {
    border-left-style: dashed;
    opacity: 0.85;
  }
  .tl-head {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem 1rem;
  }
  .tl-ep {
    color: var(--text);
    text-decoration: none;
    font-weight: 600;
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: baseline;
  }
  .tl-ep:hover {
    color: var(--accent);
  }
  .tl-epnum {
    color: var(--accent);
    font-weight: 700;
    font-size: 0.85rem;
  }
  .tl-eptitle {
    font-size: 1.02rem;
  }
  .tl-eptitle-orphan {
    color: var(--muted);
    font-style: italic;
  }
  .tl-date {
    color: var(--muted);
    font-size: 0.82rem;
    white-space: nowrap;
  }
  .tl-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    margin-top: 0.45rem;
    font-size: 0.85rem;
    color: var(--muted);
  }
  .tl-by {
    font-weight: 500;
  }
  /* Badge « œuvre d'invité » — accent ambre, cohérent avec RecoCard.
     H1 : teinte dérivée via `--guestwork` (cf. global.css) pour le contraste. */
  .tl-guestwork {
    display: inline-flex;
    align-items: center;
    gap: 0.2em;
    font-weight: 600;
    color: var(--guestwork);
    border: 1px solid color-mix(in oklab, var(--guestwork) 45%, transparent);
    background: color-mix(in oklab, var(--guestwork) 12%, transparent);
    border-radius: 999px;
    padding: 0.05em 0.5em;
    font-size: 0.78rem;
  }
  .tl-ts {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--accent);
    text-decoration: none;
    font-variant-numeric: tabular-nums;
  }
  .tl-ts:hover {
    text-decoration: underline;
  }
  .tl-audio {
    margin-top: 0.6rem;
  }
  .tl-quote {
    margin: 0.7rem 0 0;
    padding: 0.4rem 0 0.2rem 0.8rem;
    border-left: 2px solid color-mix(in oklab, var(--text) 18%, transparent);
    color: var(--text);
    font-style: italic;
    font-size: 0.92rem;
  }
</style>
