---
import { resolveLinks } from '../data/merchants';
import { TYPE_LABELS } from '../utils/recoTypes';

interface Props {
  reco: {
    id: string;
    title: string;
    creator?: string;
    types: string[];
    year?: number;
    recommendedBy?: string;
    quote?: string;
    timestamp?: string;
    links?: { label: string; url: string; kind?: string; ethics?: string }[];
    externalIds?: Record<string, string | undefined>;
    watchProviders?: { label: string; url: string; ethics?: string }[];
  };
  episodeTitle?: string;
  episodeNumber?: number;
}

const { reco, episodeTitle, episodeNumber } = Astro.props;

// Liens : ceux fournis par le pipeline, sinon générés (éthiques) à la volée.
const rawLinks =
  reco.links && reco.links.length > 0 ? reco.links : resolveLinks(reco);

// On affiche le logo (favicon) de chaque plateforme plutôt que son nom.
// Source des icônes : DuckDuckGo (respectueux de la vie privée), par domaine.
const links = rawLinks.slice(0, 4).map((l) => {
  let host = '';
  try {
    host = new URL(l.url).hostname;
  } catch {
    /* URL invalide : pas d'icône, on retombera sur le texte. */
  }
  return {
    ...l,
    host,
    icon: host ? `https://icons.duckduckgo.com/ip3/${host}.ico` : '',
  };
});

// Multi-types : on affiche le label du premier + un compteur « +N » pour les
// autres, avec tous les labels en tooltip (title=). Une reco sans types tombe
// proprement sur la chaîne vide.
const types = reco.types ?? [];
const typeLabels = types.map((t) => TYPE_LABELS[t] ?? t);
const primaryLabel = typeLabels[0] ?? '';
const typeLabel =
  typeLabels.length > 1 ? `${primaryLabel} +${typeLabels.length - 1}` : primaryLabel;
const typeTitle = typeLabels.join(', ');
const epLabel = episodeNumber ? `#${episodeNumber}` : episodeTitle ?? '';
---

<li
  class="card reveal"
  data-types={types.join(',')}
  data-search={
    // Normalisation SSR : lowercase + sans accents pour permettre une recherche
    // tolérante côté client sans avoir à re-normaliser à chaque keystroke.
    // Le range [̀-ͯ] cible les combining diacritical marks (U+0300–U+036F)
    // décomposées par NFD.
    `${reco.title} ${reco.creator ?? ''} ${typeLabel} ${episodeTitle ?? ''}`
      .normalize('NFD')
      .replace(/[̀-ͯ]/g, '')
      .toLowerCase()
  }
>
  <div class="card-top">
    <span class="type" title={typeTitle}>{typeLabel}</span>
    {reco.year && <span class="year">{reco.year}</span>}
  </div>

  <h3 class="title">{reco.title}</h3>
  {reco.creator && <p class="creator">{reco.creator}</p>}

  <div class="meta">
    {reco.recommendedBy && <span class="by">Reco de {reco.recommendedBy}</span>}
    {epLabel && <span class="ep">{epLabel}</span>}
  </div>

  {
    links.length > 0 && (
      <div class="links">
        {links.map((l) => (
          <a
            class:list={[
              'link',
              { indie: l.ethics === 'indie' },
              { avoid: l.ethics === 'avoid' },
            ]}
            href={l.url}
            target="_blank"
            rel="noopener noreferrer"
            title={
              l.ethics === 'avoid'
                ? `${l.label} (plateforme moins recommandée selon nos critères éthiques)`
                : l.label
            }
            aria-label={l.label}
          >
            {l.icon ? (
              <>
                <img
                  src={l.icon}
                  alt=""
                  width="20"
                  height="20"
                  loading="lazy"
                  data-fallback={l.label}
                  onerror="this.style.display='none';const s=this.nextElementSibling;if(s)s.hidden=false;"
                />
                <span class="link-text" hidden>{l.label}</span>
              </>
            ) : (
              <span class="link-text">{l.label}</span>
            )}
          </a>
        ))}
      </div>
    )
  }
</li>

<style>
  .card {
    background: var(--surface);
    border: 1px solid color-mix(in oklab, var(--text) 8%, transparent);
    border-radius: var(--radius);
    padding: 1.1rem 1.15rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    transition:
      transform 0.2s cubic-bezier(0.2, 0.7, 0.2, 1),
      border-color 0.2s ease;
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
  }
  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .type {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .year {
    font-size: 0.8rem;
    color: var(--muted);
  }
  .title {
    font-size: clamp(1.4rem, 2.4vw, 1.85rem);
  }
  .creator {
    margin: 0;
    color: var(--muted);
    font-weight: 500;
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.9rem;
    margin-top: auto;
    padding-top: 0.5rem;
    font-size: 0.78rem;
    color: var(--muted);
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.4rem;
  }
  /* Bouton-icône rond : on affiche le logo de la plateforme. */
  .link {
    position: relative; /* pour le badge ::after sur .avoid */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    text-decoration: none;
    background: color-mix(in oklab, var(--text) 6%, transparent);
    border: 1px solid color-mix(in oklab, var(--text) 14%, transparent);
    transition:
      transform 0.16s ease,
      border-color 0.16s ease,
      background 0.16s ease;
  }
  .link:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    background: color-mix(in oklab, var(--accent) 18%, transparent);
  }
  .link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  /* Liseré doré pour les plateformes indépendantes. */
  .link.indie {
    border-color: color-mix(in oklab, var(--accent) 55%, transparent);
  }
  /* Plateforme à éviter (Amazon/Bolloré) : opacité réduite + croix subtile
     en survol pour signaler que ce n'est pas notre premier choix. */
  .link.avoid {
    opacity: 0.5;
    filter: grayscale(0.7);
  }
  .link.avoid::after {
    content: '!';
    position: absolute;
    top: -4px;
    right: -4px;
    background: #c84a4a;
    color: #fff;
    font-size: 0.65rem;
    font-weight: 700;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .link.avoid:hover {
    opacity: 0.85;
    filter: none;
  }
  .link img {
    width: 20px;
    height: 20px;
    border-radius: 4px;
    display: block;
  }
  /* Repli si pas d'icône : on garde le nom lisible. */
  .link:has(.link-text) {
    width: auto;
    height: auto;
    border-radius: 999px;
    padding: 0.32em 0.7em;
  }
  .link-text {
    font-size: 0.8rem;
    font-weight: 600;
  }
</style>
