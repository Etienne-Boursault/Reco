# Reco — template d'environnement.
# Copier en `.env` à la racine, remplir, puis `docker compose up`.
# NE PAS committer le `.env` réel — il est ignoré (.gitignore + .dockerignore).

# ---------------------------------------------------------------------------
# Site
# ---------------------------------------------------------------------------
SITE_URL=http://localhost:4321

# ---------------------------------------------------------------------------
# Reco runtime
# ---------------------------------------------------------------------------
# Source par défaut (sous-dossier de src/content/episodes/).
RECO_SOURCE=un-bon-moment
# 1/true pour silencer les logs verbeux pendant `pipeline`.
RECO_QUIET=

# ---------------------------------------------------------------------------
# Visitor reports (P2.16) — endpoint signalements public
# ---------------------------------------------------------------------------
# Secret HMAC pour valider les reports (laisser vide en local).
REPORTS_SECRET=
# Forcer la présence du secret côté serveur (0/1).
REPORTS_REQUIRE_SECRET=
# Salt pour hash IP (PII).
REPORTS_IP_SALT=
# Liste de proxies de confiance pour parse X-Forwarded-For.
TRUSTED_PROXIES=

# ---------------------------------------------------------------------------
# Enrichments (P1.7, P2.17) — optionnels, le pipeline dégrade proprement.
# ---------------------------------------------------------------------------
# TMDB — films/séries.
TMDB_API_KEY=
# Spotify — musique.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# LLM extraction (hors compose par défaut — utile si on lance enrich/extract
# en ligne de commande dans le conteneur).
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
