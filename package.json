{
  "name": "reco",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Catalogue duplicable des recommandations de podcasts (Un Bon Moment, etc.)",
  "bin": {
    "reco": "./bin/reco"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "init": "node bin/reco init",
    "test:a11y": "node tests/a11y/check_a11y.mjs",
    "test:contrast": "node tests/a11y/check_contrast.mjs",
    "test:a11y:all": "npm run build && npm run test:a11y && npm run test:contrast",
    "test:seo": "vitest run",
    "test:og": "vitest run tests/og"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "7.1.3",
    "minisearch": "^7.2.0",
    "satori": "^0.26.0"
  },
  "devDependencies": {
    "@fontsource/bebas-neue": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@vitest/coverage-v8": "^4.1.8",
    "vitest": "^4.1.8"
  }
}
